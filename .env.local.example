# ── Supabase ──────────────────────────────────────────────
# Supabase 프로젝트 대시보드 > Settings > API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # 서버 API 전용 (절대 공개 금지)

# ── 카카오 로그인 ────────────────────────────────────────
# https://developers.kakao.com > 내 애플리케이션 > 앱 키
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_js_key
NEXT_PUBLIC_KAKAO_REST_KEY=your_kakao_rest_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret       # 보안 탭에서 활성화
NEXT_PUBLIC_KAKAO_REDIRECT_URI=https://your-domain.com/api/auth/kakao

# ── AI 요약 (선택) ────────────────────────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── 관리자 ──────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_PASSWORD=your_admin_password
